# GD31-AB17 Relay Simulator - Environment Variables Example
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# App name (optional, used in page title)
VITE_APP_NAME=GD31-AB17 Relay Simulator

# NOTE: This project (MVP v1) does not require any API keys.
# If you add external API integration in the future, define keys here
# and call them through a Vercel Serverless Function or backend API —
# do NOT embed real API keys in VITE_* variables, as they are exposed
# in the browser bundle.
